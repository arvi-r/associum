---
import Layout from '../layouts/Layout.astro';
import { Hero } from '../components/Hero.jsx';
import { WhatAssociumDoesSection } from '../components/WhatAssociumDoesSection.jsx';
import { IntegrationsSection } from '../components/IntegrationsSection.jsx';
import { HowItWorksSection } from '../components/HowItWorksSection.jsx';
import { SampleOutputsSection } from '../components/SampleOutputsSection.jsx';
import { IndustrySection } from '../components/IndustrySection.jsx';
import { DifferenceSection } from '../components/DifferenceSection.jsx';
import { SecuritySection } from '../components/SecuritySection.jsx';
import { PricingCtaSection } from '../components/PricingCtaSection.jsx';
---
<Layout
  title="Associum: Your AI Associate for Professional Work"
  description="Associum completes the full professional production cycle — data, research, analysis, and finished document — for finance, consulting, accounting, and legal professionals. Done, not drafted. Sign-off ready."
  ogTitle="Associum — Your AI Associate for Professional Work"
  ogDescription="Associum completes the full professional production cycle — data, research, analysis, and finished document — for finance, consulting, accounting, and legal professionals. Done, not drafted. Sign-off ready."
  ogImage="/associo-og-home.jpg"
  ogImageAlt="Investment committee memo generated by Associum from raw financial data — near-final, sourced, and sign-off ready"
  canonical="/"
>
  {/* Hero hydrates (above-the-fold video). Presentational sections render static
      with CSS scroll-reveal; only the interactive sections hydrate, lazily. */}
  <Hero client:load />
  <main>
    <WhatAssociumDoesSection />
    <IntegrationsSection />
    <HowItWorksSection client:visible />
    <SampleOutputsSection client:visible />
    <IndustrySection client:visible />
    <DifferenceSection />
    <SecuritySection />
    <PricingCtaSection />
  </main>
</Layout>
