<style>
/* Footer Base */
.footer {
    position: relative;
    overflow: hidden;
    padding-top: 1px;
    background: #0a111e;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 40px;
}

.footer-inner {
    position: relative;
    padding: 64px 0 24px;
    max-width: 1240px;
    margin: 0 auto;
}

.footer-top {
    display: grid;
    grid-template-columns: 268px minmax(0, 820px);
    justify-content: space-between;
    gap: 40px;
    padding-bottom: 24px;
}

/* Brand Block */
.brand-block {
    display: grid;
    gap: 20px;
    width: 268px;
}

.footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 11.885px;
    color: #f9fafb;
    text-decoration: none;
}

.footer-brand-icon {
    width: 38px;
    height: 38px;
}

.footer-brand span {
    font-family: 'Space Grotesk', Inter, system-ui, sans-serif;
    font-size: 24px;
    font-style: normal;
    font-weight: 700;
    line-height: normal;
}

.brand-copy {
    margin: 0;
    width: 265px;
    color: #92a5b5;
    font-family: Inter, system-ui, sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
}

.certifications {
    display: flex;
    align-items: center;
    gap: 20px;
}

.cert-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.cert-label {
    color: #888e9e;
    font-family: Inter, system-ui, sans-serif;
    font-size: 10px;
    font-weight: 500;
    line-height: normal;
    text-align: center;
}

.iso-badge {
    width: 45px;
    height: 45px;
}

.soc-badge {
    height: 45px;
    width: auto;
}

/* Link Columns */
.link-columns {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 160px));
    justify-content: space-between;
    gap: 20px;
}

.footer-column {
    display: grid;
    align-content: start;
    gap: 16px;
}

.footer-column h2 {
    margin: 0;
    color: #f9fafb;
    font-family: Inter, system-ui, sans-serif;
    font-size: 14px;
    font-weight: 600;
    line-height: 20px;
    text-transform: uppercase;
}

.footer-column ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 10px;
}

.footer-column li {
    padding: 2.5px 0 1.5px;
}

.footer-column a,
.footer-bottom p,
.legal-links a {
    color: #8d9aa5;
    font-family: Inter, system-ui, sans-serif;
    font-weight: 400;
    text-decoration: none;
}

.footer-column a {
    font-size: 14px;
    line-height: 20px;
}

.footer-column a:hover,
.legal-links a:hover {
    color: #f9fafb;
}

.socials {
    display: flex;
    align-items: center;
    gap: 14px;
}

.socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.socials img {
    width: 24px;
    height: 24px;
}

/* Footer Bottom */
.footer-bottom {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 25px 0 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.bottom-brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
}

.footer-bottom p,
.legal-links a {
    margin: 0;
    font-size: 12px;
    line-height: 16px;
}

.legal-links {
    display: flex;
    align-items: center;
    gap: 20px;
}

/* Watermark */
.watermark {
    position: relative;
    z-index: 0;
    width: 100%;
    margin-top: 10px;
    margin-bottom: -40px;
    display: flex;
    align-items: center;
    gap: 2vw;
    opacity: 0.08;
    pointer-events: none;
    justify-content: center;
    overflow: visible;
}

.watermark-icon {
    width: 12vw;
    max-width: 160px;
    height: auto;
    object-fit: contain;
    flex: 0 0 auto;
}

.watermark span {
    background: linear-gradient(180deg, #fff 9.248%, #0a111e 77.116%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: 'Space Grotesk', Inter, system-ui, sans-serif;
    font-size: 16vw;
    font-style: normal;
    font-weight: 700;
    line-height: 0.8;
    white-space: nowrap;
}

/* Media Queries */
@media (max-width: 1199px) {
    .watermark-icon {
        width: 12vw;
    }

    .watermark span {
        font-size: 14vw;
    }

    .footer-top {
        grid-template-columns: minmax(0, 1fr);
    }

    .brand-block {
        width: 100%;
        padding-left: 20px;
    }

    .brand-copy {
        width: min(100%, 420px);
    }

    .link-columns {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 32px 20px;
        padding-left: 20px;
        padding-right: 20px;
    }

    .footer-bottom {
        padding-left: 20px;
        padding-right: 20px;
    }
}

@media (max-width: 767px) {
    .footer-inner {
        padding-top: 48px;
        padding-bottom: 20px;
    }

    .footer-top {
        gap: 32px;
    }

    .link-columns {
        grid-template-columns: minmax(0, 1fr);
    }

    .footer-bottom {
        flex-direction: column;
        align-items: flex-start;
        padding-left: 20px;
        padding-right: 20px;
    }

    .legal-links {
        flex-wrap: wrap;
    }
}


@media (max-width: 425px) {
    .brand-block {
        width: 100%;
        padding-left: 20px;
        padding-right: 20px;
    }
}
</style>
