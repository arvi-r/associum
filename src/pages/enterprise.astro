---
import Layout from '../layouts/Layout.astro';
import { ButtonLink } from '../components/ButtonLink.jsx';
---

<Layout title="Enterprise Page | Associum">


    <!-- Header will be injected here -->
    

    <main class="enterprise-main">
        <section class="enterprise-hero">
            <div class="hero-content">
                <h1 class="hero-title" data-reveal="true" style="--reveal-delay: 0.1s">Realize value from AI today by
                    adding Associum to your team.</h1>
                <p class="hero-subtitle" data-reveal="true" style="--reveal-delay: 0.2s">Your whole firm can collaborate
                    around AI-driven insights with Associum.</p>
                <div class="hero-actions" data-reveal="true" style="--reveal-delay: 0.3s">
                    <ButtonLink href="#" variant="primary" size="heroPrimary">Talk to our Enterprise Team</ButtonLink>
                    <ButtonLink href="#" variant="outline" size="heroSecondary">See Security Details</ButtonLink>
                </div>
                <p class="hero-footer-text" data-reveal="true" style="--reveal-delay: 0.4s">SOC 2 Type II &middot; ISO
                    27001 &middot; Zero data retention. Your data
                    never trains any model.</p>
            </div>
        </section>

        <section class="team-section">
            <div class="team-header">
                <span class="team-label" data-reveal="true" style="--reveal-delay: 0.1s">WHO IT'S FOR</span>
                <h2 class="team-title" data-reveal="true" style="--reveal-delay: 0.2s">Built for your entire team</h2>
                <p class="team-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum works across your full
                    team.</p>
            </div>
            <div class="team-grid">
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.1s">
                    <h3 class="team-card-title">Analysts and Associates</h3>
                    <p class="team-card-desc">Research, synthesis and near-final drafts in minutes. Your team spends
                        time on judgement, not information and document production logistics</p>
                </div>
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.2s">
                    <h3 class="team-card-title">Management and Senior Professionals</h3>
                    <p class="team-card-desc">Every output sourced and cited. Review what came back, use Associum to
                        dive deeper into results, and complete work with precision.</p>
                </div>
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.3s">
                    <h3 class="team-card-title">Information Technology</h3>
                    <p class="team-card-desc">SSO, SCIM, role-based access, audit logs. Provisioning is automated. Takes
                        days, not months.</p>
                </div>
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.4s">
                    <h3 class="team-card-title">Compliance and Risk</h3>
                    <p class="team-card-desc">SOC 2 Type II and ISO 27001 certified. Zero data retention. Your data
                        never trains any model. DPA and GDPR documentation ready for your procurement team.</p>
                </div>
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.5s">
                    <h3 class="team-card-title">Finance</h3>
                    <p class="team-card-desc">Internal financials tracking, reporting, and investor relations on a
                        combined platform. Transparency in AI spend.</p>
                </div>
                <div class="team-card" data-reveal="true" style="--reveal-delay: 0.6s">
                    <h3 class="team-card-title">Operations</h3>
                    <p class="team-card-desc">Onboarding takes days, not months. Support for workflow transition and
                        team training.</p>
                </div>
            </div>
        </section>

        <section class="connect-section">
            <div class="connect-container">
                <div class="connect-left">
                    <div class="connect-header">
                        <span class="connect-label" data-reveal="true"
                            style="--reveal-delay: 0.1s">INFRASTRUCTURE</span>
                        <h2 class="connect-title" data-reveal="true" style="--reveal-delay: 0.2s">Connects to your
                            preferred<br>systems and data sources</h2>
                        <p class="connect-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum connects to the
                            tools your firm already uses using MCP. Connect
                            any
                            MCP, and we'll help you test and implement it.</p>
                    </div>
                    <img src="/assets/images/enterprise/infrastructure/image1.png" alt="Integrations"
                        class="connect-integrations-img" data-reveal="zoom" style="--reveal-delay: 0.4s">
                </div>

                <div class="connect-right">
                    <div class="connect-card" data-reveal="true" style="--reveal-delay: 0.1s">
                        <div class="connect-card-icon">
                            <img src="/assets/images/enterprise/infrastructure/database.svg" alt="Private databases"
                                width="20" height="20">
                        </div>
                        <div class="connect-card-content">
                            <h3>Private databases and internal knowledge</h3>
                            <p>Your firm's proprietary data. Indexed, searchable, queryable. Stays in your environment.
                            </p>
                        </div>
                    </div>
                    <div class="connect-card" data-reveal="true" style="--reveal-delay: 0.2s">
                        <div class="connect-card-icon">
                            <img src="/assets/images/enterprise/infrastructure/mcp.svg" alt="MCP integrations"
                                width="20" height="20">
                        </div>
                        <div class="connect-card-content">
                            <h3>MCP integrations</h3>
                            <p>Live connections to your data sources. No manual exports. No copy-paste between tools.
                            </p>
                        </div>
                    </div>
                    <div class="connect-card" data-reveal="true" style="--reveal-delay: 0.3s">
                        <div class="connect-card-icon">
                            <img src="/assets/images/enterprise/infrastructure/api.svg" alt="API access" width="20"
                                height="20">
                        </div>
                        <div class="connect-card-content">
                            <h3>API access</h3>
                            <p>Custom integrations available for firms embedding Associum into proprietary platforms,
                                internal workflows, or client-facing tools.</p>
                        </div>
                    </div>
                    <div class="connect-card" data-reveal="true" style="--reveal-delay: 0.4s">
                        <div class="connect-card-icon">
                            <img src="/assets/images/enterprise/infrastructure/private.svg"
                                alt="Private and Hybrid clouds" width="20" height="20">
                        </div>
                        <div class="connect-card-content">
                            <h3>Private and Hybrid clouds</h3>
                            <p>Available for firms with specific security, compliance, or infrastructure requirements.
                                Deployment options can be tailored to your needs.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="metrics-section">
            <div class="metrics-container">
                <div class="metric-item" data-reveal="true" style="--reveal-delay: 0.1s">
                    <h2 class="metric-title">8 hr &nbsp;&rarr;&nbsp; 10 min</h2>
                    <p class="metric-subtitle">Hours of production becomes minutes of review.</p>
                </div>
                <div class="metric-divider"></div>
                <div class="metric-item" data-reveal="true" style="--reveal-delay: 0.2s">
                    <h2 class="metric-title">1 Standard</h2>
                    <p class="metric-subtitle">Every analyst. Every output. Every time.</p>
                </div>
                <div class="metric-divider"></div>
                <div class="metric-item" data-reveal="true" style="--reveal-delay: 0.3s">
                    <h2 class="metric-title">Day 1</h2>
                    <p class="metric-subtitle">Open it. Use it. Review what comes back.</p>
                </div>
            </div>
        </section>

        <section class="deployment-section">
            <div class="deployment-header">
                <span class="deployment-label" data-reveal="true" style="--reveal-delay: 0.1s">DEPLOYMENT</span>
                <h2 class="deployment-title" data-reveal="true" style="--reveal-delay: 0.2s">Onboard quickly with our
                    secure cloud platform</h2>
                <p class="deployment-desc" data-reveal="true" style="--reveal-delay: 0.3s">We can tailor Associum to
                    your specific deployment needs.</p>
            </div>

            <div class="deployment-grid">
                <div class="deployment-col" data-reveal="true" style="--reveal-delay: 0.1s">
                    <div class="deployment-badge">Recommended for most Teams</div>
                    <h3 class="deployment-col-title">Shared cloud</h3>
                    <p class="deployment-col-desc">Secure multi-tenant infrastructure. SOC 2 Type II certified. Zero
                        data retention. Running in hours.</p>
                    <ul class="deployment-features">
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Fastest deployment</li>
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Automatic updates</li>
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Lowest operational overhead</li>
                    </ul>
                </div>

                <div class="deployment-col" data-reveal="true" style="--reveal-delay: 0.2s">
                    <div class="deployment-badge">Most isolation</div>
                    <h3 class="deployment-col-title">Single- tenant cloud</h3>
                    <p class="deployment-col-desc">Your own dedicated environment. Fully isolated from other customers.
                        Your region of choice.</p>
                    <ul class="deployment-features">
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Dedicated infrastructure</li>
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Custom data residency</li>
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> No shared compute or storage</li>
                    </ul>
                </div>

                <div class="deployment-col" data-reveal="true" style="--reveal-delay: 0.3s">
                    <div class="deployment-badge">Maximum Control</div>
                    <h3 class="deployment-col-title">Private cloud</h3>
                    <p class="deployment-col-desc">For organizations with specialized security needs, we can work with
                        you to develop a custom private deployment approach.</p>
                    <ul class="deployment-features">
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Designed around your security and compliance needs</li>
                        <li><svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <circle cx="8" cy="8" r="8" fill="#E1F4EF" />
                                <path d="M11.5 5.5L6.5 10.5L4.5 8.5" stroke="#0F8560" stroke-width="1.5"
                                    stroke-linecap="round" stroke-linejoin="round" />
                            </svg> Enterprise team support throughout</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="security-section">
            <div class="security-header">
                <span class="security-label" data-reveal="true" style="--reveal-delay: 0.1s">SECURITY AND
                    COMPLIANCE</span>
                <h2 class="security-title" data-reveal="true" style="--reveal-delay: 0.2s">Enterprise-grade security to
                    protect your data</h2>
                <p class="security-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum delivers high accuracy
                    results in a secure and confidential
                    environment.</p>
            </div>

            <div class="security-grid-wrapper">
                <div class="security-grid">
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.1s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/training.svg" alt="No training on your data"
                                width="20" height="20">
                        </div>
                        <h3 class="security-card-title">No training on your data</h3>
                        <p class="security-card-desc">No file you upload, task you run, or output you generate is ever
                            used to train any AI model, ours or our providers.</p>
                    </div>
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.2s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/enterprise.svg"
                                alt="Enterprise-grade traceability" width="20" height="20">
                        </div>
                        <h3 class="security-card-title">Enterprise-grade traceability</h3>
                        <p class="security-card-desc">Associum connects every generated insight back to its original
                            documents, filings, and research sources for maximum trust and accountability.</p>
                    </div>
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.3s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/encryption.svg" alt="End-to-end encryption"
                                width="20" height="20">
                        </div>
                        <h3 class="security-card-title">End-to-end encryption</h3>
                        <p class="security-card-desc">Every file, every query, every output is encrypted in transit and
                            at rest, keys managed independently.</p>
                    </div>
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.4s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/role.svg"
                                alt="Role-based access and audit logs" width="20" height="20">
                        </div>
                        <h3 class="security-card-title">Role-based access and audit logs</h3>
                        <p class="security-card-desc">Always audit-ready. Define exactly who can view, edit, or export.
                            Every action logged.</p>
                    </div>
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.5s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/sso.svg" alt="SSO and SCIM provisioning"
                                width="20" height="20">
                        </div>
                        <h3 class="security-card-title">SSO and SCIM provisioning</h3>
                        <p class="security-card-desc">No manual account management. User access syncs automatically with
                            your identity system. SAML 2.0, OAuth 2.0, Okta, Azure AD, Google Workspace.</p>
                    </div>
                    <div class="security-card" data-reveal="true" style="--reveal-delay: 0.6s">
                        <div class="security-card-icon">
                            <img src="/assets/images/enterprise/security/network.svg"
                                alt="Network control and observability" width="20" height="20">
                        </div>
                        <h3 class="security-card-title">Network control and observability</h3>
                        <p class="security-card-desc">Access restricted to approved networks. Compliance teams get
                            programmatic visibility into usage via the Compliance API.</p>
                    </div>
                </div>
            </div>

            <div class="security-certs">
                <div class="cert-left">
                    <div class="securitycert-item" data-reveal="true" style="--reveal-delay: 0.1s">
                        <img src="/assets/images/enterprise/security/iso.png" alt="ISO 27001" width="40" height="40"
                            onerror="this.style.display='none'">
                        <div class="cert-text">
                            <h4>ISO 27001</h4>
                            <span>Certified</span>
                        </div>
                    </div>
                    <div class="securitycert-item" data-reveal="true" style="--reveal-delay: 0.2s">
                        <img src="/assets/images/enterprise/security/soc.png" alt="SOC 2 Type II" width="40" height="40"
                            onerror="this.style.display='none'">
                        <div class="cert-text">
                            <h4>SOC 2 Type II</h4>
                            <span>Independently audited</span>
                        </div>
                    </div>
                </div>

                <div class="cert-action" data-reveal="true" style="--reveal-delay: 0.3s">
                    <button class="btn-full-security">Full Security Details</button>
                </div>
            </div>
        </section>

        <section class="pricing-section">
            <div class="pricing-header">
                <span class="pricing-label" data-reveal="true" style="--reveal-delay: 0.1s">PRICING AND
                    COMMERCIAL</span>
                <h2 class="pricing-title" data-reveal="true" style="--reveal-delay: 0.2s">Built for cost transparency
                    and control</h2>
                <p class="pricing-desc" data-reveal="true" style="--reveal-delay: 0.3s">Usage-based pricing with pooled
                    credits to meet the needs of your team and
                    provide transparency to AI costs.</p>
            </div>

            <div class="pricing-grid">
                <div class="pricing-card" data-reveal="true" style="--reveal-delay: 0.1s">
                    <h3 class="pricing-card-title">Usage and pricing</h3>
                    <p class="pricing-card-desc">Pooled across the organisation. Heavy users draw from the same pool as
                        light users. No idle credits, no seat-level overages.</p>
                    <ul class="pricing-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Pooled credits managed centrally by your admin
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            User and org-level spend limits
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Volume discounts for large credit pre-payments
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Annual contracts, credits roll monthly
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Multi-year options available
                        </li>
                    </ul>
                </div>
                <div class="pricing-card" data-reveal="true" style="--reveal-delay: 0.2s">
                    <h3 class="pricing-card-title">Procurement and support</h3>
                    <p class="pricing-card-desc">Enterprise procurement has its own process. We work inside it. Once
                        you're in, you have a named contact, not a ticketing system.</p>
                    <ul class="pricing-list">
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Custom MSA available
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            PO and invoice billing
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            DPA and GDPR documentation ready for signing
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Security questionnaires and NDA on request
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Dedicated enterprise contact with priority SLA
                        </li>
                        <li>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                                <polyline points="12 5 19 12 12 19"></polyline>
                            </svg>
                            Most firms are live within 7 business days
                        </li>
                    </ul>
                </div>
            </div>

            <div class="pricing-action" data-reveal="true" style="--reveal-delay: 0.2s">
                <button class="btn-full-security">Talk to our Enterprise Team</button>
            </div>
        </section>

        <section class="faq-section">
            <div class="faq-container">
                <div class="faq-header">
                    <span class="faq-label" data-reveal="true" style="--reveal-delay: 0.1s">Frequently Asked
                        Questions</span>
                    <h2 class="faq-title" data-reveal="true" style="--reveal-delay: 0.2s">What enterprise buyers ask
                    </h2>
                </div>
                <div class="faq-list">
                    <div class="faq-item active" data-reveal="true" style="--reveal-delay: 0.1s">
                        <button class="faq-question">
                            Does our data get used to train your AI models?
                            <span class="faq-icon">−</span>
                        </button>
                        <div class="faq-answer" style="max-height: 200px;">
                            <p>No. Your data is your own. We do not use any data from enterprise customers to train our
                                base models or any other models.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.2s">
                        <button class="faq-question">
                            Can we deploy Associum on our own infrastructure?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. We offer single-tenant cloud and private cloud deployment options for organizations
                                with specific infrastructure requirements.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.3s">
                        <button class="faq-question">
                            What does onboarding look like for a team of 20?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
