    font-weight: 400;
    color: #64748B;
    margin-left: 16px;
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
}

.faq-answer p {
    margin: 0 0 24px 0;
    color: #888E9E;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
}

.faq-footer {
    margin: 0;
    color: #888E9E;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    line-height: normal;
    width: 100%;
    max-width: 800px;
    text-align: left;
}

/* Pricing Section */
.pricing-section {
    display: flex;
    width: 1440px;
    max-width: 100%;
    margin: 0 auto;
    padding: 100px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 40px;
    background-color: #FFF;
    box-sizing: border-box;
}

.pricing-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.pricing-label {
    color: #0F8560;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 1px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
}

.pricing-title {
    color: #0F0F10;
    font-family: 'Lato', sans-serif;
    font-size: 36px;
    font-weight: 700;
    margin: 0;
}

.pricing-desc {
    color: #888E9E;
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    font-weight: 400;
    width: 100%;
    max-width: 900px;
    line-height: 30px;
    margin: 12px 0 0 0;
}

.pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    width: 100%;
    gap: 24px;
}

.pricing-card {
    display: flex;
    padding: 40px;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    border-radius: 12px;
    border: 1px solid #E6EAEF;
    background: #F8FAFB;
    box-sizing: border-box;
}

.pricing-card-title {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 24px;
    font-weight: 600;
    margin: 0;
}

.pricing-card-desc {
    color: #555F75;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    margin: 0;
}

.pricing-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: 10px;
}

.pricing-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #555F75;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 22px;
}

.pricing-list li svg {
    flex-shrink: 0;
    margin-top: 3px;
}

.pricing-action {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 20px;
}


