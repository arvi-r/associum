---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blogs | Associum">


    <!-- Header will be injected here -->
    

    <main class="blogs-container">
        <section class="blogs-hero">
            <h1 class="hero-title" data-reveal="true" style="--reveal-delay: 0.1s">Explore<br><span
                    class="hero-title-gradient">Trending Blogs</span></h1>
            <p class="hero-subtitle" data-reveal="true" style="--reveal-delay: 0.2s">Stay updated with engaging blogs,
                insights, and stories for modern readers and
                businesses.</p>
        </section>

        <section class="blogs-content-section">
            <div class="tabs-container" id="blogs-tabs-container" data-reveal="true" style="--reveal-delay: 0.3s">
                <div class="tab-slider" id="tab-slider"></div>
                <button class="tab tab-active">All</button>
                <button class="tab">Finance</button>
                <button class="tab">Consulting</button>
                <button class="tab">Accounting</button>
                <button class="tab">Compliance</button>
            </div>

            <div class="blogs-grid" id="blogs-grid">
                <!-- Dynamically populated by blogs.js -->
            </div>

            <div class="pagination-wrapper" id="pagination-wrapper" data-reveal="true" style="--reveal-delay: 0.2s">
                <div class="pagination">
                    <button class="page-btn page-nav-btn" id="btn-first" aria-label="First page">
                        <img src="/assets/images/templates/templates/arrow-left-2.svg" alt="First" class="page-arrow">
                    </button>
                    <button class="page-btn page-nav-btn" id="btn-prev" aria-label="Previous page">
                        <img src="/assets/images/templates/templates/arrow-left-1.svg" alt="Previous" class="page-arrow">
                    </button>
                    <div class="page-numbers" id="page-numbers-container" style="display: flex; gap: 12px; align-items: center;">
                        <!-- Page numbers will be rendered dynamically -->
                    </div>
                    <button class="page-btn page-nav-btn" id="btn-next" aria-label="Next page">
                        <img src="/assets/images/templates/templates/arrow-right-1.svg" alt="Next" class="page-arrow">
                    </button>
                    <button class="page-btn page-nav-btn" id="btn-last" aria-label="Last page">
                        <img src="/assets/images/templates/templates/arrow-right-2.svg" alt="Last" class="page-arrow">
                    </button>
                </div>
            </div>
        </section>

        <section class="cta-section">
            <div class="cta-container">
                <div class="cta-content">
                    <h2 class="cta-title" data-reveal="true" style="--reveal-delay: 0.1s">Stay Updated With Fresh
                        Insights
                    </h2>
                    <p class="cta-text" data-reveal="true" style="--reveal-delay: 0.2s">Get the latest articles, expert
                        ideas, and industry trends delivered directly to
                        your inbox every week.</p>
                </div>

                <a href="#" class="cta-button" data-reveal="true" style="--reveal-delay: 0.3s">Subscribe Now</a>
            </div>
        </section>
    </main>

    <!-- Footer will be injected here -->
    <footer id="footer-placeholder"></footer>

    <!-- Component Loader Script -->
    
    

</Layout>

<style>
html,
body {
    overflow-x: hidden;
}

.blogs-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #FFF;
    width: 100%;
    overflow-x: hidden;
}

.blogs-hero {
    display: flex;
    width: 100%;
    max-width: 1440px;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 10px;
    background: #FFF;
    padding: 160px 100px 80px;
}

.hero-title {
    color: var(--Text-Primary, #0F0F10);
    text-align: center;
    font-family: 'Lato', sans-serif;
    font-size: 60px;
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
    margin: 0;
}

.hero-title-gradient {
    background: linear-gradient(92deg, #059466 -4.04%, #09523B 103.36%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: 'Lato', sans-serif;
    font-size: 60px;
    font-style: normal;
    font-weight: 700;
    line-height: 140%;
}

.hero-subtitle {
    color: var(--Text-Secondary, #323741);
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 28px;
    margin: 0;
    max-width: 700px;
}

.blogs-content-section {
    display: flex;
    padding: 60px 100px 100px 100px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 60px;
    align-self: stretch;
    background: linear-gradient(137deg, #F9FAFB -1.77%, #FFF 101.65%);
    width: 100%;
    box-sizing: border-box;
}

.tabs-container {
    display: flex;
    align-items: center;
    width: 100%;
    position: relative;
    /* border-bottom: 1px solid var(--Neutral-200, #EAEDF2); */
    gap: 32px;
}

.tab {
    display: flex;
    padding: 16px 8px;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    background: transparent;
    border: none;
    color: var(--Text-Teritiary, #888E9E);
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    transition: color 0.3s ease;
    white-space: nowrap;
}

.tab:hover {
    color: #27272A;
}

.tab.tab-active {
    color: transparent;
    background: #059466;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
}

.tab-slider {
    position: absolute;
    bottom: -1px;
    height: 3px;
    background: linear-gradient(92deg, #FFF -4.04%, #C1F6E5 26.94%, #08C186 103.36%);
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1), width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    left: 0;
    width: 0;
    border-radius: 2px;
}

.blogs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    width: 100%;
    grid-auto-rows: 1fr;
    /* equal height rows */
}

:global(.blog-card) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    flex: 1 0 0;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    height: 100%;
    /* ensure full height within grid row */
}

:global(.blog-card:hover) {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
}

:global(.blog-card-image) {
    height: 200px;
    /* consistent responsive height */
    width: 100%;
    object-fit: cover;
    align-self: stretch;
    border-top-left-radius: 10px;
    border-top-right-radius: 10px;
    border-bottom: 1px solid var(--Neutral-200, #EAEDF2);
}

:global(.blog-card-content) {
    display: flex;
    flex-direction: column;
    flex: 1;
    /* expand to fill remaining card height */
    background: #FFFFFF;
    padding: 24px;
    align-items: flex-start;
    gap: 16px;
    border: 1px solid var(--Neutral-200, #EAEDF2);
    border-bottom-left-radius: 10px;
    border-bottom-right-radius: 10px;
    align-self: stretch;
}

:global(.blog-card-title) {
    color: var(--Neutral-800, #0E1218);
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    margin: 0;
}

:global(.blog-card-text) {
    overflow: hidden;
    color: #0F0F10;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    white-space: normal;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 24px;
    opacity: 0.6;
    margin: 0;
}

:global(.blog-card-footer) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    align-self: stretch;
    margin-top: auto;
}

:global(.blog-card-date) {
    color: var(--Text-Teritiary, #888E9E);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
}

:global(.blog-card-readtime) {
    display: flex;
    align-items: center;
    gap: 6px;
    color: var(--Neutral-500, #555F75);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 18px;
    opacity: 0.7;
}

/* Pagination */
.pagination-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 20px;
}

.pagination {
    display: flex;
    align-items: center;
    gap: 12px;
}

:global(.page-btn) {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #FBFBFB;
    border: 1px solid #EAEDF2;
    color: #555F75;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    min-width: 40px;
    height: 40px;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0 6px;
}

:global(.page-btn:hover) {
    background: #EAEDF2;
    border-color: #CCD2DD;
    color: #0F0F10;
}

:global(.page-btn.active) {
    background: linear-gradient(91.6deg, #05704E 4%, #09573E 103%);
    border-color: #0F8560;
    color: #FFFFFF;
    font-weight: 600;
}

:global(.page-btn.active:hover) {
    background: linear-gradient(91.6deg, #05704E 4%, #09573E 103%);
    color: #FFFFFF;
}

:global(.page-btn.disabled) {
    opacity: 0.4;
    pointer-events: none;
    cursor: not-allowed;
}

.page-dots {
    color: #888E9E;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    padding: 0 4px;
}

.page-arrow {
    width: auto;
    height: 18px;
    display: block;
    transition: filter 0.2s ease, opacity 0.2s ease;
    opacity: 0.8;
}

:global(.page-btn:hover .page-arrow) {
    filter: brightness(0.4) contrast(1.5);
    opacity: 1;
}

.cta-section {
    display: flex;
    padding: 60px 100px 100px 100px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 60px;
    align-self: stretch;
    background: linear-gradient(137deg, #F9FAFB -1.77%, #FFF 101.65%);
    width: 100%;
    box-sizing: border-box;
}

.cta-content {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 872px;
    align-items: center;
}

.cta-container {
    display: flex;
    padding: 50px 24px;
    flex-direction: column;
    align-items: center;
    align-self: stretch;
    border-radius: 12px;
    background: linear-gradient(135deg, #2D323A 3.69%, #0A111E 72.96%);
    gap: 24px;
}

.cta-title {
    color: #FFF;
    text-align: center;
    font-family: 'Lato', sans-serif;
    font-size: 40px;
    font-style: normal;
    font-weight: 700;
    line-height: 45px;
    letter-spacing: -0.2px;
    margin: 0;
}

.cta-text {
    color: #CCD2DDFF;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    margin: 0;
    max-width: 800px;
}

.cta-button {
    display: flex;
    height: 48px;
    padding: 0 32px;
    justify-content: center;
    align-items: center;
    border-radius: 8px;
    border: 1px solid #0F8560;
    background: linear-gradient(92deg, #05704E -4.04%, #09573E 103.36%);
    color: #FFF;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 600;
    line-height: 24px;
    text-decoration: none;
    margin-top: 16px;
    transition: 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
}

.cta-button:hover {
    border-color: #0f8560;
    background: linear-gradient(301deg, #09523b 3.57%, #059466 158.11%);
    box-shadow: inset 0 0 0 0.5px #0f8560;
}

@media screen and (min-width: 880px) and (max-width: 1224px) {
    .blogs-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media screen and (min-width: 480px) and (max-width: 879px) {
    .blogs-hero {
        padding-left: 40px;
        padding-right: 40px;
        padding-top: 160px;
        padding-bottom: 80px;
    }

    .blogs-content-section {
        padding-left: 40px;
        padding-right: 40px;
        padding-top: 60px;
        padding-bottom: 60px;
    }

    .cta-section {
        padding-left: 40px;
        padding-right: 40px;
        padding-top: 60px;
        padding-bottom: 60px;
    }

    .blogs-grid {
        grid-template-columns: repeat(1, 1fr);
    }
}

@media screen and (max-width: 479px) {

    .blogs-hero h1,
    .hero-title-gradient {
        font-size: 40px;
    }

    .tab-active {
        width: 120px;
        height: 40px;
    }

    .tab-inactive {
        width: 120px;
        height: 40px;
    }

    .tab-active-text {
        font-size: 16px;
    }

    .blogs-hero {
        padding-left: 20px;
        padding-right: 20px;
        padding-top: 160px;
        padding-bottom: 60px;
        gap: 10px;
    }

    .cta-title {
        font-size: 28px;
    }

    .cta-text {
        font-size: 16px;
    }

    .cta-content {
        padding: 16px;
        gap: 20px;
    }

    .hero-subtitle {
        font-size: 16px;
    }

    .blogs-content-section {
        gap: 24px;
    }

    .blogs-grid {
        grid-template-columns: 1fr;
    }

    .tabs-container {
        height: 54px;
        overflow-x: scroll;
        overflow-y: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        white-space: nowrap;
    }

    .tab {
        min-width: max-content;
    }

    .blogs-content-section,
    .cta-section {
        padding: 40px 16px 50px 16px;
    }

    .cta-button {
        height: 48px;
        min-width: 180px;
        font-size: 16px;
        font-weight: 600;
        line-height: 24px;
    }

    .blogs-grid {
        grid-template-columns: repeat(1, 1fr);
    }
}

@media screen and (max-width: 1024px) {

    .hero-title,
    .hero-title-gradient {
        font-size: 48px;
        line-height: 120%;
    }

    .cta-title {
        font-size: 36px;
    }

    .cta-section {
        padding: 40px 40px;
    }
}

@media screen and (max-width: 768px) {

    .hero-title,
    .hero-title-gradient {
        font-size: 40px;
    }

    .cta-title {
        font-size: 34px;
    }

    .cta-text {
        font-size: 18px;
    }
}

@media screen and (max-width: 425px) {
    .cta-title {
        font-size: 28px;
    }

    .cta-text {
        font-size: 16px;
    }

    .blogs-hero h1,
    .hero-title-gradient {
        font-size: 30px;
    }
}

@media (max-width: 480px) {
    :global(.page-btn) {
        min-width: 34px;
        height: 34px;
        font-size: 14px;
    }

    .cta-section {
        padding: 20px 16px;
    }

    .cta-container {
        padding: 30px 16px;
    }
}
