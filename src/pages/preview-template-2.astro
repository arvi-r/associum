---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Preview Template | Associum">

    

    <main class="preview-main">
        <section class="preview-hero">
            <div class="preview-container">
                <a href="/templates" class="back-link">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                    <span>Back to Templates</span>
                </a>

                <div class="preview-content-box" id="preview-content-box">
                    <div class="preview-details">
                        <span class="category-text" id="tpl-category">Finance</span>
                        <h1 class="template-title" id="tpl-title">Portfolio Company Quarterly Review</h1>
                        <p class="template-meta" id="tpl-meta">Slides | 14-18 Pages</p>

                        <div class="template-desc" id="tpl-desc">
                            <p>A private equity board-pack style review of a portfolio company's operational and financial performance against plan. Tracks KPIs, EBITDA bridges, strategic initiative progress, value creation plan updates, and current implied returns.</p>
                            <p>Ideal for PE operating partners, portfolio company CFOs, and investment committee members reviewing asset performance.</p>
                        </div>

                        <div class="template-contents">
                            <h3>Contents</h3>
                            <ol id="tpl-contents">
                                <li>Company Overview</li>
                                <li>Investment Snapshot</li>
                                <li>Quarter in Review</li>
                                <li>Financial Scorecard</li>
                                <li>P&L Bridge</li>
                                <li>Revenue Deep Dive</li>
                                <li>Margin Analysis</li>
                                <li>Cash & Working Capital</li>
                                <li>Strategic Initiatives Tracker</li>
                                <li>Sales & Commercial</li>
                                <li>Headcount & HR</li>
                                <li>Value Creation Plan Update</li>
                                <li>Returns Update</li>
                                <li>90-Day Priorities</li>
                                <li>Appendix</li>
                            </ol>
                        </div>
                    </div>

                    <div class="preview-visuals">
                        <div class="preview-header">
                            <span class="file-name"><span id="tpl-filename">Portfolio Company Quarterly Review</span>.
                                <span class="file-ext">pptx</span></span>
                        </div>
                        <div class="preview-viewer">
                            <div class="main-cover">
                                <img src="/assets/images/preview-template-2/preview/preview_fin_008_01.png"
                                    id="tpl-main-img" alt="Cover">
                            </div>
                            <div class="thumbnails-container">
                                <button class="nav-arrow left-nav-arrow" aria-label="Previous page">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="15 18 9 12 15 6"></polyline>
                                    </svg>
                                </button>
                                <div class="thumbnails">
                                    <div class="thumb-wrapper">
                                        <div class="thumb active">
                                            <img src="/assets/images/preview-template-2/thumbnail/preview_fin_008_01.png"
                                                id="tpl-thumb-1" alt="Thumb 1">
                                        </div>
                                    </div>
                                    <div class="thumb-wrapper">
                                        <div class="thumb">
                                            <img src="/assets/images/preview-template-2/thumbnail/preview_fin_008_02.png"
                                                alt="Thumb 2">
                                        </div>
                                    </div>
                                    <div class="thumb-wrapper">
                                        <div class="thumb">
                                            <img src="/assets/images/preview-template-2/thumbnail/preview_fin_008_03.png"
                                                alt="Thumb 3">
                                        </div>
                                    </div>
                                    <div class="thumb-wrapper">
                                        <div class="thumb blurred">
                                            <img src="/assets/images/preview-template-2/thumbnail/preview_fin_008_04.png"
                                                alt="Thumb 4">
                                            <div class="blur-overlay">
                                                <div class="overlay-content">
                                                    <p>Create a free Associum account to access the complete document and
                                                        additional templates.</p>
                                                    <button class="btn-signup">www.associum.ai</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <button class="nav-arrow right-nav-arrow" aria-label="Next page">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="9 18 15 12 9 6"></polyline>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <button class="btn-get-started">Get Started for Free</button>
            </div>
        </section>

        <!-- Related Templates -->
        <section class="related-templates">
            <div class="related-container">
                <h2 class="related-title">Related Templates</h2>
                <div class="templates-grid" id="related-grid">
                    <!-- Loaded dynamically via JS -->
                </div>
            </div>
        </section>
    </main>

    <footer id="footer-placeholder"></footer>

    
    

</Layout>

<style>
/* Preview Template CSS */

.preview-main {
    background-color: #FFFFFF;
    width: 100%;
    overflow: hidden;
}

/* Hero/Preview Section */
.preview-hero {
    display: flex;
    justify-content: center;
    padding: 180px 24px 100px 24px;
}

.preview-container {
    max-width: 1240px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #888E9E;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    text-decoration: none;
    transition: color 0.2s ease;
    align-self: flex-start;
}

.back-link:hover {
    color: #0F0F10;
}

/* Split Content Box */
.preview-content-box {
    display: flex;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
}

/* Left Pane */
.preview-details {
    width: 530px;
    display: flex;
    flex-direction: column;
    padding: 20px;
    background: #FFFFFF;
    border: 1px solid #EAEDF2;
    border-right: none;
    border-radius: 12px 0 0 12px;
    gap: 10px;
    height: 700px;
    overflow-y: auto;
}

.category-text {
    color: #056F4D;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 500;
}

.template-title {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.44px;
    margin: 0;
}

.template-meta {
    color: #323741;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 400;
    margin: 0;
}

.template-desc {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 10px;
    color: #323741;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 24px;
}

.template-desc p {
    margin: 0;
}

.template-contents {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.template-contents h3 {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.44px;
}

.template-contents ol {
    margin: 0;
    padding-left: 24px;
    color: #323741;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 32px;
}

/* Right Pane - Viewer */
.preview-visuals {
    flex: 1;
    display: flex;
    flex-direction: column;
    border: 1px solid #EAEDF2;
    border-radius: 0 12px 12px 0;
    overflow: hidden;
    height: 700px;
}

.preview-header {
    background: #F8FAFB;
    border-bottom: 1px solid #EAEDF2;
    padding: 16px;
    display: flex;
    align-items: center;
}

.file-name {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
}

.file-ext {
    color: #888E9E;
}

/* Custom Scrollbar for viewer panels */
.main-cover::-webkit-scrollbar,
.thumbnails::-webkit-scrollbar {
    width: 6px;
    height: 6px;
}

.main-cover::-webkit-scrollbar-track,
.thumbnails::-webkit-scrollbar-track {
    background: transparent;
    margin: 10px 0;
}

.main-cover::-webkit-scrollbar-thumb,
.thumbnails::-webkit-scrollbar-thumb {
    background: #E5E7EB;
    border-radius: 4px;
}

.preview-viewer {
    background: #F3F4F6;
    display: flex;
    flex-direction: column;
    padding: 24px;
    gap: 16px;
    align-items: stretch;
    flex: 1;
    overflow: hidden;
}

.main-cover {
    background: #FFFFFF;
    flex: 1;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 24px;
    overflow: hidden;
}

.main-cover img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    border: 1px solid #EAEDF2;
    border-radius: 6px;
    box-shadow: none;
}

.thumbnails-container {
    background: #FFFFFF;
    border-radius: 12px;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    padding: 16px 24px;
    gap: 16px;
}

.nav-arrow {
    background: transparent;
    border: none;
    outline: none;
    color: #888E9E;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 8px;
    transition: color 0.2s ease;
}

.nav-arrow:hover {
    color: #0F0F10;
}

.thumbnails {
    background: transparent;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: 16px;
    flex: 1;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 8px 0;
}

.thumb-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: auto;
    flex-shrink: 0;
}

.thumb {
    position: relative;
    width: 126px;
    height: 76px;
    border: 1px solid #EAEDF2;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
}

.thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.thumb.active {
    border: 2px solid #0F8560;
}

.thumb-number {
    display: none;
}

.thumb.blurred img {
    filter: blur(1px);
}


.blur-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
}

.overlay-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 10px;
    text-align: center;
}

.overlay-content p {
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
}

.btn-signup {
    background: #0F8560;
    border: 1px solid #14A377;
    border-radius: 4px;
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-size: 8px;
    font-weight: 600;
    padding: 4px 8px;
    cursor: pointer;
}

/* CTA Button */
.btn-get-started {
    height: 48px;
    display: flex;
    justify-content: center;
    align-items: center;
    background: linear-gradient(97deg, #05704E 4%, #09573E 103%);
    border: 1px solid #0F8560;
    border-radius: 8px;
    color: #FFFFFF;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s ease;
    width: 250px;
    align-self: flex-end;
}

.btn-get-started:hover {
    opacity: 0.9;
}

/* Related Templates Section */
.related-templates {
    background: #F8FAFB;
    padding: 100px 24px;
    display: flex;
    justify-content: center;
}

.related-container {
    max-width: 1240px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 40px;
}

.related-title {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 32px;
    font-weight: 600;
    margin: 0;
}

.templates-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
}

/* Template Card (Reused styles) */
:global(.template-card) {
    background: #FDFDFD;
    border: 1px solid #EAEDF2;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: all 0.3s ease;
}

:global(.template-card):hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(10, 17, 30, 0.05);
}

:global(.card-image-wrap) {
    position: relative;
    height: 240px;
    width: 100%;
    overflow: hidden;
    background: #EAEDF2;
}

:global(.card-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
}

:global(.template-card):hover :global(.card-img) {
    transform: scale(1.03);
}

.category-badge {
    position: absolute;
    left: 20px;
    bottom: 20px;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    color: #FFFFFF;
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 8px;
    text-transform: uppercase;
}

:global(.card-info) {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-grow: 1;
}

:global(.card-title) {
    color: #0F0F10;
    font-family: 'Inter', sans-serif;
    font-size: 22px;
    font-weight: 600;
    margin: 0;
    letter-spacing: -0.44px;
}

:global(.card-desc) {
    color: #0F0F10;
    opacity: 0.6;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 24px;
    margin: 0;
}

:global(.card-footer) {
    padding: 12px 20px 20px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #EAEDF2;
}

.file-type {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #555F75;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
}

:global(.btn-preview) {
    position: relative;
    border: 1px solid #37B793;
    background: transparent;
    color: #37B793;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    border-radius: 8px;
    cursor: pointer;
    z-index: 1;
    overflow: hidden;
    transition: color 0.3s ease, border-color 0.3s ease;
}

:global(.btn-preview)::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(137deg, #059466 4%, #09523b 103%);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
}

:global(.btn-preview):hover {
    color: #FFFFFF;
    border-color: transparent;
}

:global(.btn-preview):hover::before {
    opacity: 1;
}

/* Responsive */
@media (max-width: 1024px) {
    .preview-content-box {
        flex-direction: column;
    }

    .preview-details {
        width: 100%;
        border-right: 1px solid #EAEDF2;
        border-bottom: none;
        border-radius: 12px 12px 0 0;
        max-height: none;
    }

    .preview-visuals {
        border-radius: 0 0 12px 12px;
    }

    .templates-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (max-width: 768px) {
    .preview-hero {
        padding-top: 140px;
    }

    .related-templates {
        padding: 60px 24px;
    }

    .btn-get-started {
        width: 100%;
    }
}

@media (max-width: 480px) {
    .templates-grid {
        grid-template-columns: 1fr;
    }

    .thumbnails {
        flex-wrap: wrap;
    }
}
</style>

<script is:inline>
// Preview Template 2 Page JS

document.addEventListener('astro:page-load', () => {
    renderRelatedTemplates();
    setupThumbnails();
});

function setupThumbnails() {
    const thumbs = document.querySelectorAll('.thumb');
    const mainImg = document.getElementById('tpl-main-img');
    const mainCover = document.querySelector('.main-cover');
    const leftArrow = document.querySelector('.left-nav-arrow');
    const rightArrow = document.querySelector('.right-nav-arrow');

    if (mainCover) {
        mainCover.style.position = 'relative';
    }

    thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
            // Remove active class from all
            thumbs.forEach(t => t.classList.remove('active'));
            // Add active class to clicked
            thumb.classList.add('active');
            
            // Update main image src
            const img = thumb.querySelector('img');
            if (img && mainImg) {
                let src = img.src;
                if (src.includes('/thumbnail/')) {
                    src = src.replace('/thumbnail/', '/preview/').replace('Interior', 'Cover');
                }
                mainImg.src = src;
            }

            // Handle blurred state
            if (thumb.classList.contains('blurred')) {
                mainImg.style.filter = 'blur(2px)';
                
                if (!document.getElementById('main-blur-overlay')) {
                    const overlay = document.createElement('div');
                    overlay.id = 'main-blur-overlay';
                    overlay.style.position = 'absolute';
                    overlay.style.top = '0';
                    overlay.style.left = '0';
                    overlay.style.right = '0';
                    overlay.style.bottom = '0';
                    overlay.style.background = 'rgba(0, 0, 0, 0.6)';
                    overlay.style.display = 'flex';
                    overlay.style.flexDirection = 'column';
                    overlay.style.alignItems = 'center';
                    overlay.style.justifyContent = 'center';
                    overlay.style.gap = '16px';
                    overlay.style.textAlign = 'center';
                    overlay.style.padding = '20px';
                    overlay.style.borderRadius = '12px';
                    overlay.innerHTML = `
                        <p style="color: white; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; line-height: 1.4; margin: 0; max-width: 320px;">Create a free Associum account to access the complete document and additional templates.</p>
                        <button style="background: #0F8560; border: 1px solid #14A377; border-radius: 6px; color: white; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; padding: 10px 20px; cursor: pointer;">www.associum.ai</button>
                    `;
                    mainCover.appendChild(overlay);
                }
            } else {
                mainImg.style.filter = 'none';
                const overlay = document.getElementById('main-blur-overlay');
                if (overlay) overlay.remove();
            }

            // Smoothly scroll the thumb into view horizontally
            thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        });
    });

    // Arrow navigation
    if (leftArrow) {
        leftArrow.addEventListener('click', () => {
            const activeThumb = document.querySelector('.thumb.active');
            const thumbArray = Array.from(thumbs);
            let activeIndex = thumbArray.indexOf(activeThumb);
            if (activeIndex !== -1) {
                let nextIndex = activeIndex - 1;
                if (nextIndex < 0) nextIndex = thumbArray.length - 1;
                thumbArray[nextIndex].click();
            }
        });
    }

    if (rightArrow) {
        rightArrow.addEventListener('click', () => {
            const activeThumb = document.querySelector('.thumb.active');
            const thumbArray = Array.from(thumbs);
            let activeIndex = thumbArray.indexOf(activeThumb);
            if (activeIndex !== -1) {
                let nextIndex = activeIndex + 1;
                if (nextIndex >= thumbArray.length) nextIndex = 0;
                thumbArray[nextIndex].click();
            }
        });
    }
}

function renderRelatedTemplates() {
    const gridContainer = document.getElementById('related-grid');
    if (!gridContainer) return;

    const relatedData = [
        {
            title: "Sector Thematic Research Report",
            desc: "Establish a structural investment thesis with company profiles, trade ideas, and price targets.",
            category: "Finance",
            img: "/assets/images/templates/templates/template-04.png",
            fileType: "PDF Report",
            link: "../preview-template-1/preview-template-1.html"
        },
        {
            title: "Private Equity Buyout IC Paper",
            desc: "Present a buyout to your IC with everything needed to make a decision, from thesis to returns.",
            category: "Finance",
            img: "/assets/images/templates/templates/template-05.png",
            fileType: "PDF Report",
            link: "../preview-template-1/preview-template-1.html"
        },
        {
            title: "Equity Research Initiation Report",
            desc: "Initiate coverage with an institutional-quality report — thesis, valuation, financials, and risks.",
            category: "Finance",
            img: "/assets/images/templates/templates/template-04.png",
            fileType: "PDF Report",
            link: "../preview-template-1/preview-template-1.html"
        }
    ];

    const pdfIconSvg = `
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
        <polyline points="14 2 14 8 20 8"></polyline>
        <line x1="16" y1="13" x2="8" y2="13"></line>
        <line x1="16" y1="17" x2="8" y2="17"></line>
        <polyline points="10 9 9 9 8 9"></polyline>
    </svg>`;

    const pptIconSvg = `
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="14" rx="2" ry="2"></rect>
        <line x1="12" y1="22" x2="12" y2="16"></line>
        <line x1="8" y1="22" x2="16" y2="22"></line>
        <line x1="12" y1="10" x2="8" y2="10"></line>
        <line x1="12" y1="6" x2="16" y2="6"></line>
    </svg>`;

    relatedData.forEach(item => {
        const card = document.createElement('div');
        card.className = 'template-card';

        const iconSvg = item.fileType === 'PPT Deck' ? pptIconSvg : pdfIconSvg;

        card.innerHTML = `
            <div class="card-image-wrap">
                <img src="${item.img}" alt="${item.title}" class="card-img">
                <span class="category-badge">${item.category}</span>
            </div>
            <div class="card-info">
                <h3 class="card-title">${item.title}</h3>
                <p class="card-desc">${item.desc}</p>
            </div>
            <div class="card-footer">
                <div class="file-type">
                    ${iconSvg}
                    <span>${item.fileType}</span>
                </div>
                <button class="btn-preview" onclick="window.location.href='${item.link}'">Preview Template</button>
            </div>
        `;

        gridContainer.appendChild(card);
    });
}

</script>
