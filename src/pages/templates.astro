---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Professional Templates | Associum">


    <!-- Header placeholder (loaded dynamically) -->
    

    <main class="templates-main">
        <section class="templates-hero">
            <div class="hero-container" data-reveal="true" style="--reveal-delay: 0.1s">
                <h1 class="hero-title">
                    <span class="title-professional">Professional Templates </span>
                    <span class="title-built-for">Built for Real Work</span>
                </h1>
                <p class="hero-subtitle">Access a growing library of AI-powered templates designed to produce
                    professional reports, analyses, and presentations faster than ever.</p>
            </div>
        </section>

        <section class="browse-section">
            <div class="browse-container">
                <div class="browse-header" data-reveal="true" style="--reveal-delay: 0.1s">
                    <div class="header-text">
                        <h2 class="browse-title">Browse Professional Templates</h2>
                        <p class="browse-subtitle">Choose a category to explore templates designed for your workflow</p>
                    </div>
                    <div class="header-controls" style="position: relative;">
                        <button class="control-btn btn-filters" id="btn-filters-toggle">
                            <svg class="icon-filter" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="4" y1="21" x2="4" y2="14"></line>
                                <line x1="4" y1="10" x2="4" y2="3"></line>
                                <line x1="12" y1="21" x2="12" y2="12"></line>
                                <line x1="12" y1="8" x2="12" y2="3"></line>
                                <line x1="20" y1="21" x2="20" y2="16"></line>
                                <line x1="20" y1="12" x2="20" y2="3"></line>
                                <line x1="1" y1="14" x2="7" y2="14"></line>
                                <line x1="9" y1="8" x2="15" y2="8"></line>
                                <line x1="17" y1="16" x2="23" y2="16"></line>
                            </svg>
                            <span>Filters</span>
                        </button>

                        <!-- Filter Popup -->
                        <div class="filter-popup" id="filter-popup">
                            <div class="filter-popup-header">
                                <h3>Filters</h3>
                                <button class="btn-close-filter" id="btn-close-filter" aria-label="Close filters">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0F0F10"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="18" y1="6" x2="6" y2="18"></line>
                                        <line x1="6" y1="6" x2="18" y2="18"></line>
                                    </svg>
                                </button>
                            </div>
                            <div class="filter-popup-body">
                                <div class="filter-group">
                                    <h4>Category</h4>
                                    <div class="filter-options">
                                        <button class="filter-option" data-category="Finance">Finance</button>
                                        <button class="filter-option" data-category="Consulting">Consulting</button>
                                        <button class="filter-option" data-category="Accounting">Accounting</button>
                                        <button class="filter-option" data-category="Compliance">Compliance</button>
                                    </div>
                                </div>
                                <div class="filter-group">
                                    <h4>Format</h4>
                                    <div class="filter-options">
                                        <button class="filter-option format-option" data-format="PDF">PDF</button>
                                        <button class="filter-option format-option" data-format="PPTX">PPTX</button>
                                    </div>
                                </div>
                            </div>
                            <div class="filter-popup-footer">
                                <button class="btn-filter-reset" id="btn-filter-reset">Reset</button>
                                <button class="btn-filter-apply" id="btn-filter-apply">Apply</button>
                            </div>
                        </div>

                        <div class="search-box">
                            <svg class="icon-search" width="18" height="18" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            <input type="text" placeholder="Search templates..." class="search-input" id="search-input">
                            <button class="btn-clear-search" id="btn-clear-search" aria-label="Clear search">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="templates-grid">
                    <div class="template-card" data-category="Finance" data-format="PDF Report" data-reveal="true"
                        style="--reveal-delay: 0.1s">
                        <div class="card-image-wrap">
                            <img src="/assets/images/templates/templates/template-01.png" alt="Economic Research Report"
                                class="card-img">
                            <span class="category-badge">Finance</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-title">Economic Research Report</h3>
                            <p class="card-desc">Generate institutional-grade investment committee memos with market
                                analysis, risks, valuation insights, and recommendations.</p>
                        </div>
                        <div class="card-footer">
                            <div class="file-type">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10 9 9 9 8 9"></polyline>
                                </svg>
                                <span>PDF Report</span>
                            </div>
                            <button class="btn-preview"
                                onclick="window.location.href='/preview-template-1'">Preview
                                Template</button>
                        </div>
                    </div>

                    <div class="template-card" data-category="Research" data-format="PDF Report" data-reveal="true"
                        style="--reveal-delay: 0.2s">
                        <div class="card-image-wrap">
                            <img src="/assets/images/templates/templates/template-02.png" alt="Market Research Report"
                                class="card-img">
                            <span class="category-badge">Research</span>
                        </div>
                        <div class="card-info">
                            <h3 class="card-title">Market Research Report</h3>
                            <p class="card-desc">Analyze industries, competitors, TAM, growth drivers, and market
                                opportunities using AI-powered research.</p>
                        </div>
                        <div class="card-footer">
                            <div class="file-type">
