---
import Layout from '../layouts/Layout.astro';
import { ButtonLink } from '../components/ButtonLink.jsx';
---

<Layout title="Compliance | Associum">


    <!-- Header will be injected here -->
    

    <main class="finance-main">
        <section class="finance-hero">
            <div class="hero-inner">
                <div class="hero-left">
                    <div class="hero-pill" data-reveal="true" style="--reveal-delay: 0.1s">
                        <span class="pill-dot"></span>
                        <span class="pill-text">FOR COMPLIANCE</span>
                    </div>
                    <h1 class="hero-title" data-reveal="true" style="--reveal-delay: 0.2s">Your AI Associate <br><span
                            class="hero-highlight">on the Compliance Team</span></h1>
                    <p class="hero-desc" data-reveal="true" style="--reveal-delay: 0.3s">From board resolutions to
                        regulatory gap analyses, Associum compresses days of research and documentation and
                        cross-referencing into hours, without cutting corners without cutting corners on corporate
                        governance standards.
                    </p>
                    <div class="hero-actions" data-reveal="true" style="--reveal-delay: 0.4s">
                        <ButtonLink href="#" variant="primary" size="heroPrimary">Start for Free</ButtonLink>
                        <ButtonLink href="#" variant="outline" size="heroSecondary">Explore Enterprise Solutions</ButtonLink>
                    </div>
                </div>
                <div class="hero-right" data-reveal="zoom" style="--reveal-delay: 0.5s">
                    <img src="/assets/images/compliance/hero/compliance-hero.png" alt="Dashboard Interface"
                        class="hero-image" />
                </div>
            </div>
        </section>

        <section class="workflow-section">
            <div class="workflow-container">
                <div class="workflow-header">
                    <h2 class="workflow-title" data-reveal="true" style="--reveal-delay: 0.1s">An AI-powered end-to-end
                        workflow</h2>
                    <p class="workflow-desc" data-reveal="true" style="--reveal-delay: 0.2s">Associum's agents manage
                        the entire workflow of policy review, testing, and documentation, from raw inputs to compliance
                        reviews, from analysis to a near-final deliverable.</p>
                </div>

                <div class="workflow-track">
                    <div class="workflow-line" aria-hidden="true"></div>

                    <div class="workflow-cards">
                        <!-- Card 1 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.1s">
                            <span class="card-number">01</span>
                            <h3 class="card-title">Data Ingestion</h3>
                            <p class="card-text">Upload documents and datasets from any source. Associum reads,
                                classifies, and enriches every file with third-party data and deep web research.</p>
                            <div class="card-footer">
                                <span>Unstructured &rarr; Understanding</span>
                            </div>
                        </div>

                        <!-- Card 2 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.2s">
                            <span class="card-number">02</span>
                            <h3 class="card-title">Data Extraction</h3>
                            <p class="card-text">Key obligations, findings, and risk factors are extracted and indexed,
                                each traced to its exact source document and page.</p>
                            <div class="card-footer">
                                <span>Data &rarr; Evidence</span>
                            </div>
                        </div>

                        <!-- Card 3 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.3s">
                            <span class="card-number">03</span>
                            <h3 class="card-title">Findings Synthesis</h3>
                            <p class="card-text">Findings are structured against the relevant policy, precedent, or risk
                                framework, calibrated to the output type.</p>
                            <div class="card-footer">
                                <span>Information &rarr; Insight</span>
                            </div>
                        </div>

                        <!-- Card 4 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.4s">
                            <span class="card-number">04</span>
                            <h3 class="card-title">Document Generation</h3>
                            <p class="card-text">Associum produces a near-final resolution, gap analysis, or report,
                                formatted and structured, ready for your review.</p>
                            <div class="card-footer">
                                <span>Insight &rarr; Draft</span>
                            </div>
                        </div>

                        <!-- Card 5 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.5s">
                            <span class="card-number">05</span>
                            <h3 class="card-title">Review and Sign off</h3>
                            <p class="card-text">Refine the output in-platform. Verify the conclusions, apply firm
                                conventions. Every element is editable before it leaves your hands.</p>
                            <div class="card-footer">
                                <span>Draft &rarr; Decision</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="roles-section">
            <div class="roles-container">
                <div class="roles-header">
                    <span class="roles-label" data-reveal="true" style="--reveal-delay: 0.1s">WHO IT IS FOR</span>
                    <h2 class="roles-title" data-reveal="true" style="--reveal-delay: 0.2s">Built for every compliance
                        role.</h2>
                    <p class="roles-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum handles the work of
                        different corporate secretarial and compliance roles, each with distinct outputs and workflows.
                    </p>
                </div>

                <div class="roles-layout" data-reveal="true" style="--reveal-delay: 0.1s">
                    <div class="roles-tabs" id="roles-tabs">
                        <button class="role-tab active" data-role="corp-secretarial">
                            Corporate Secretarial
                        </button>
                        <button class="role-tab" data-role="regulatory-compliance">
                            Regulatory Compliance
                        </button>
                        <button class="role-tab" data-role="governance-esg">
                            Governance & ESG
                        </button>
                        <button class="role-tab" data-role="kyc">
                            KYC & Onboarding
                        </button>
                    </div>

                    <div class="role-content">
                        <div class="role-content-header">
                            <span class="content-label" id="role-content-label">CORPORATE SECRETARIAL</span>
                            <div class="role-title-group">
                                <h3 class="content-title" id="role-content-title">Delegate corporate documentation of
                                    meetings, resolutions, and corporate actions in consistent format across every
                                    entity, every time.</h3>
                                <p class="content-desc" id="role-content-desc">Associum prepares the board resolutions,
                                    statutory filings, and minutes with consistency and precision, across a growing list
                                    of entities and jurisdictions.</p>
                            </div>
                        </div>

                        <div class="content-features">
                            <h4 class="features-label">WHAT ASSOCIUM HANDLES</h4>
                            <ul class="features-list" id="role-features-list">
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Gets context from past board packs, meeting notes, and governance
                                        documentation.</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Structures the documents, resolutions, or minutes against firm templates and
                                        precedents.</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Drafts statutory documents in a near-final form for your review and
                                        sign-off.</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>You manage governance, not repetitive documentation.</span>
                                </li>
                            </ul>
                        </div>

                        <div class="content-divider"></div>

                        <div class="content-sample">
                            <span class="features-label">SAMPLE OUTPUT</span>
                            <div class="sample-card">
                                <div class="sample-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                        <polyline points="10 9 9 9 8 9"></polyline>
                                    </svg>
                                </div>
                                <div class="sample-info">
                                    <h5 id="role-sample-title">Board Resolution Pack</h5>
                                    <p id="role-sample-desc">Statutory resolutions and minutes drafted from board packs,
                                        consistent across entities and filings.</p>
                                </div>
                                <button class="sample-btn">Preview Template</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="insight-section">
            <div class="insight-container">
                <div class="insight-left">
                    <span class="insight-label" data-reveal="true" style="--reveal-delay: 0.1s">SOURCE- TRUTH
                        INSIGHT</span>
                    <h2 class="insight-title" data-reveal="true" style="--reveal-delay: 0.2s">Detailed citations support
                        fact base and conclusions.</h2>
                    <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.3s">Analysis and generated files
                        stay on the platform for long-term availability and retrospective review.</p>
                    <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.4s">If this file is inspected in
                        two years, the trail is already there. The judgment stays with you — the defensibility comes
                        built in.</p>
                    <!-- <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.4s">You review the work. You
                        verify the sources. The judgment stays with you.</p> -->
                </div>
                <div class="insight-right" style="padding: 0; background: transparent; border: none; overflow: hidden;">
                    <video autoplay loop muted playsinline style="width: 100%; object-fit: cover; border-radius: 24px;">
                        <source src="/assets/images/finance/source/source.mov">
                        Your browser does not support the video tag.
                    </video>
                </div>
            </div>
        </section>

        <section class="automation-section">
            <div class="automation-container">
                <div class="automation-header">
                    <span class="automation-label" data-reveal="true" style="--reveal-delay: 0.1s">WORKFLOW
                        AUTOMATION</span>
                    <h2 class="automation-title" data-reveal="true" style="--reveal-delay: 0.2s">The work Associum
                        handles</h2>
                    <p class="automation-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum supports the
                        entire workflow of template production, research on regulatory and compliance issues, and
                        document production. Your assessment and conclusions, supported by Associum.</p>
                </div>

                <div class="automation-layout" data-reveal="true" style="--reveal-delay: 0.1s">
                    <!-- Left Column: Without Associum -->
                    <div class="automation-col without-associum">
                        <div class="col-header">
                            <span class="col-badge">WITHOUT ASSOCIUM</span>
                            <h3 class="col-title">You take on the document work.You lose the hours to it.</h3>
                        </div>
                        <div class="pills-grid">
                            <span class="task-pill"><span class="pill-dot"></span>Review company policies</span>
                            <span class="task-pill"><span class="pill-dot"></span>Research new and upcoming
                                regulations</span>
                            <span class="task-pill"><span class="pill-dot"></span>Cross-reference risk exposures</span>
                            <span class="task-pill"><span class="pill-dot"></span>Chase internal compliance</span>
                            <span class="task-pill"><span class="pill-dot"></span>Map the regulatory impact</span>
                            <span class="task-pill"><span class="pill-dot"></span>Assess compliance implementation steps
                                and costs</span>
                            <span class="task-pill"><span class="pill-dot"></span>Draft section by section</span>
                            <span class="task-pill"><span class="pill-dot"></span>Format to precedent</span>
                            <span class="task-pill"><span class="pill-dot"></span>Review for each entity</span>
                            <span class="task-pill"><span class="pill-dot"></span>Reconfirm all the details</span>
                            <span class="task-pill"><span class="pill-dot"></span>Rework after review notes</span>
                        </div>
                    </div>

                    <!-- Divider Arrow -->
                    <div class="automation-divider-arrow">
                        <div class="arrow-circle">
                            <svg width="10" height="18" viewBox="0 0 10 18" fill="none" stroke="#37B793"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="2 2 8 9 2 16"></polyline>
                            </svg>
                        </div>
                    </div>

                    <!-- Right Column: With Associum -->
                    <div class="automation-col with-associum">
                        <div class="col-header">
                            <span class="col-badge badge-green">WITH ASSOCIUM</span>
                            <h3 class="col-title title-green">You provide direction and context. Associum handles the
                                rest.</h3>
                        </div>
                        <div class="pills-grid">
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Policy mapping
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Synthesis
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Drafting
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Cross-referencing
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Formatting
                            </span>
                        </div>

                        <div class="col-footer-card">
                            <div class="footer-card-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10 9 9 9 8 9"></polyline>
                                </svg>
                            </div>
                            <div class="footer-card-info">
                                <h4>You review the draft</h4>
                                <p>Accurate, cited and ready for review</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="automation-bottom-banner" data-reveal="true" style="--reveal-delay: 0.2s">
                    <h3>Get up-to-speed on compliance issues in minutes, not days.</h3>
                    <p>Review company policies, research new regulation, and produce draft reviews in less than 30
                        minutes. Spend your time on questions, assessments, and conclusions, not documentation.</p>
                </div>
            </div>
        </section>

        <section class="impact-section">
            <div class="impact-container">
                <div class="impact-header">
                    <h2 class="impact-title" data-reveal="true" style="--reveal-delay: 0.1s">What it means for risk and
                        audit readiness</h2>
                    <p class="impact-desc" data-reveal="true" style="--reveal-delay: 0.2s">A missed deadline or an
                        inconsistent file is a risk event, not just a productivity loss. Associum's value compounds
                        across the compliance function as exposure to regulatory and audit risk, not just hours saved.
                    </p>
                </div>

                <div class="impact-grid" data-reveal="true" style="--reveal-delay: 0.3s">
                    <!-- Card 1 -->
                    <div class="impact-card">
                        <div class="impact-card-header">
                            <h3>Missed deadlines</h3>
                            <span class="impact-badge">Reduced</span>
                        </div>
                        <p class="impact-card-text">Regulatory changes are mapped to affected policies faster, closing
                            the gap between a new obligation and an updated policy.</p>
                    </div>
                    <!-- Card 2 -->
                    <div class="impact-card">
                        <div class="impact-card-header">
                            <h3>Audit readiness</h3>
                            <span class="impact-badge">Stronger</span>
                        </div>
                        <p class="impact-card-text">Every file carries a built-in audit trail back to its source, ready
                            for inspection without a scramble to reconstruct it later.</p>
                    </div>
                    <!-- Card 3 -->
                    <div class="impact-card">
                        <div class="impact-card-header">
                            <h3>Consistency across entities</h3>
                            <span class="impact-badge">Higher</span>
                        </div>
                        <p class="impact-card-text">Every resolution, filing, and file follows the same precedent and
                            standard, reducing the risk of inconsistent treatment across entities.</p>
                    </div>
                    <!-- Card 4 -->
                    <div class="impact-card">
                        <div class="impact-card-header">
                            <h3>Coverage capacity</h3>
                            <span class="impact-badge">Expanded</span>
                        </div>
                        <p class="impact-card-text">The same team covers more regulatory change, more entities, and more
                            KYC files without proportional headcount growth.</p>
                    </div>
                </div>

                <div class="impact-footer-banner" data-reveal="true" style="--reveal-delay: 0.4s">
                    <p><strong>This is a risk-reduction lever, not just a productivity tool.</strong> Built for CCOs,
                        GCs, and compliance leads evaluating exposure, defensibility, and coverage capacity.</p>
                </div>
            </div>
        </section>

        <section class="faq-section">
            <div class="faq-container">
                <h2 class="faq-title" data-reveal="true" style="--reveal-delay: 0.1s">Common Questions from Compliance
                    Professionals</h2>

                <div class="faq-list">
                    <div class="faq-item active" data-reveal="true" style="--reveal-delay: 0.1s">
                        <button class="faq-question">
                            Does Associum work with the document types we actually use in compliance?
                            <span class="faq-icon">−</span>
                        </button>
                        <div class="faq-answer" style="max-height: 200px;">
                            <p>Yes. Associum is built to handle board packs, regulatory guidance, screening results,
                                policy documents, and governance data. It reads the full document, not just the first
                                few pages.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.2s">
                        <button class="faq-question">
                            What stops it from hallucinating or making up findings?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Every finding and claim in an Associum output is traced back to a specific source
                                document, page, and section. If it can't find something in the documents you've
                                uploaded, it won't invent it.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.3s">
                        <button class="faq-question">
                            Will the output hold up if this file is reviewed by a regulator later?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Every conclusion carries a built-in audit trail back to its source. If a file needs to be
                                reconstructed or reviewed months or years later, the trail is already documented, not
                                reconstructed after the fact</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.4s">
                        <button class="faq-question">
                            Is our client and entity data secure?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Associum is SOC 2 certified and ISO 27001 compliant. Your documents are never used to
                                train any Al model. Data handling details are available on our Security page.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.5s">
                        <button class="faq-question">
                            How long does it take to get a usable output?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Most users have a structured first draft (resolution, gap analysis, or report) within
                                20-30 minutes of uploading their documents, depending on document volume.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.5s">
                        <button class="faq-question">
                            Do I need to set anything up or train it on our firm's style?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>No setup required. Upload your documents and start. For teams that want outputs in a
                                specific house format, templates can be configured, but it works out of the box from day
                                one.</p>
                        </div>
                    </div>
                </div>

                <p class="faq-footer" data-reveal="true" style="--reveal-delay: 0.2s">Still have a question? Use the
                    form on our Contact page and we'll be in touch within one business day.</p>
            </div>
        </section>

        <section class="cta-section">
            <div class="cta-wrapper">
                <div class="cta-container">
                    <h2 class="cta-title" data-reveal="true" style="--reveal-delay: 0.1s">From board notes to near-final
                        resolutions.<br>In one environment.</h2>
                    <p class="cta-desc" data-reveal="true" style="--reveal-delay: 0.2s">Free to start. No credit card
                        required.</p>
                    <div class="cta-buttons" data-reveal="true" style="--reveal-delay: 0.3s">
                        <button class="cta-btn-primary">Start for Free</button>
                        <button class="cta-btn-outline">See Pricing</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer will be injected here -->
    <footer id="footer-placeholder"></footer>

    <!-- Component Loader Script -->
    
    <!-- Compliance Script -->
    

</Layout>

<style>
.finance-main {
    display: block;
    min-height: auto;
    padding: 0;
    background-color: transparent;
}

.finance-hero {
    display: flex;
    height: auto;
    /* Allow height to adapt */
    min-height: 650px;
    padding: 200px 80px 160px 80px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    flex-shrink: 0;
    align-self: stretch;
    background: linear-gradient(205deg, #054D49 25.28%, #041413 89%);
    overflow: hidden;
}

.hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    gap: 30px;
    height: 100%;
}

.hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 23.1px;
    flex: 1 0 0;
}

.hero-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5.5px 15px 5.64px;
    border-radius: 9999px;
    background: rgba(52, 211, 153, 0.12);
    border: 1px solid rgba(52, 211, 153, 0.25);
}

.hero-pill .pill-dot {
    position: relative;
    width: 6px;
    height: 6px;
    background-color: #34D399;
    border-radius: 50%;
    box-shadow: 0px 0px 8px 0px #34D399;
}

.hero-pill .pill-dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    background-color: #34D399;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.8;
    animation: pill-dot-active 2s infinite cubic-bezier(0.25, 0, 0, 1);
}

.pill-text {
    color: #34D399;
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.1px;
    text-transform: uppercase;
}

@keyframes pill-dot-active {
    0% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.8;
    }

    100% {
        transform: translate(-50%, -50%) scale(3.5);
        opacity: 0;
    }
}

