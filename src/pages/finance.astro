/* Responsive Styles */
@media (max-width: 1120px) {
    .roles-container {
        padding: 60px 40px;
    }
}

@media (max-width: 991px) {
    .roles-layout {
        flex-direction: column;
        align-items: stretch;
    }

    .roles-tabs {
        width: 100%;
        min-width: 100%;
        flex-direction: row;
        border-right: 1px solid #EAEDF2;
        border-bottom: none;
        border-radius: 16px 16px 0 0;
        flex-wrap: nowrap;
        overflow-x: auto;
        justify-content: flex-start;
        padding-bottom: 0;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }

    .roles-tabs::-webkit-scrollbar {
        display: none;
    }

    .role-tab {
        flex: 0 0 auto;
        width: auto;
        height: 52px;
        padding: 0 20px;
        border-top: none !important;
        border-right: 1px solid #EAEDF2;
    }

    .role-tab:not(:first-child) {
        border-left: none;
    }

    .role-tab:first-child {
        border-radius: 15px 0 0 0;
    }

    .role-tab:last-child {
        border-right: none;
        border-radius: 0 15px 0 0;
    }

    .role-tab.active {
        border-right: none;
        border-bottom: 3px solid #37B793;
        margin-right: 0;
        margin-bottom: -1px;
        /* Overlap border top of content container */
        z-index: 2;
    }

    .role-content {
        border-radius: 0 0 16px 16px;
        border-top: none;
    }
}

@media (max-width: 768px) {
    .roles-container {
