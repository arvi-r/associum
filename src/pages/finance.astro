/* Workflow Section */
.workflow-section {
    display: flex;
    justify-content: center;
    background: #F8F9FA;
}

.workflow-container {
    display: flex;
    width: 100%;
    max-width: 1440px;
    padding: 100px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 60px;
}

.workflow-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.workflow-title {
    margin: 0;
    color: #323741;
    font-family: 'Lato', sans-serif;
    font-size: 36px;
    font-weight: 700;
    line-height: normal;
    letter-spacing: -0.2px;
}

.workflow-desc {
    margin: 0;
    color: #888E9E;
    font-family: Inter, sans-serif;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 26px;
    letter-spacing: -0.2px;
    width: 100%;
    max-width: 824px;
}

.workflow-track {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
}

.workflow-line {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    border-top: 2px dashed #08C186;
    z-index: 0;
    opacity: 0.5;
}

.workflow-cards {
    display: flex;
    gap: 20px;
    position: relative;
    z-index: 1;
    width: 100%;
    overflow-x: auto;
    padding-bottom: 20px;
    /* For scrollbar */
}

.workflow-cards::-webkit-scrollbar {
    height: 6px;
}

.workflow-cards::-webkit-scrollbar-thumb {
    background: #CBD5E1;
    border-radius: 4px;
}

.workflow-card {
    display: flex;
    width: 236px;
    /* min-width: 236px; */
    padding: 24px;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    border-radius: 20px;
    border: 1px solid #EAEDF2;
    background: #FFF;
}

.card-number {
    color: #08C186;
    font-family: Inter, sans-serif;
    font-size: 16px;
    font-weight: 700;
}

.card-title {
    margin: 0;
    color: #323741;
    font-family: Inter, sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 4px;
}

.card-text {
    margin: 0;
    color: #888E9E;
    font-family: Inter, sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    flex-grow: 1;
}

.card-footer {
    display: inline-flex;
    padding: 6px 8px;
    justify-content: center;
    align-items: center;
    border-radius: 6px;
    background: rgba(8, 193, 134, 0.10);
    margin-top: 8px;
    width: 100%;
    box-sizing: border-box;
}

.card-footer span {
    color: #0F8560;
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 600;
}

/* Responsive tweaks for workflow */
@media (max-width: 1120px) {
