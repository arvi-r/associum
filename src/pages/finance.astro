}

.sample-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 24px;
    border-radius: 16px;
    border: 1px solid #EAEDF2;
    background: #FCFCFD;
}

.sample-icon {
    display: flex;
    padding: 10px;
    justify-content: center;
