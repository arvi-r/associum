---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Finance | Associum">


    <!-- Header will be injected here -->
    

    <main class="finance-main">
        <section class="finance-hero">
            <div class="hero-inner">
                <div class="hero-left">
                    <div class="hero-pill" data-reveal="true" style="--reveal-delay: 0.1s">
                        <span class="pill-dot"></span>
                        <span class="pill-text">FOR FINANCE</span>
                    </div>
                    <h1 class="hero-title" data-reveal="true" style="--reveal-delay: 0.2s">Your AI Associate <br><span
                            class="hero-highlight">on the Deal Team</span></h1>
                    <p class="hero-desc" data-reveal="true" style="--reveal-delay: 0.3s">From financial models to IC
                        memos, Associum compresses days of work into hours, without cutting corners on precision or
                        quality.</p>
                    <div class="hero-actions" data-reveal="true" style="--reveal-delay: 0.4s">
                        <a href="#" class="button-link button-primary hero-btn">Start for Free</a>
                        <a href="#" class="button-link button-outline hero-btn">Explore Enterprise Solutions</a>
                    </div>
                </div>
                <div class="hero-right" data-reveal="zoom" style="--reveal-delay: 0.5s">
                    <img src="/assets/images/finance/hero/finance-hero.png" alt="Dashboard Interface"
                        class="hero-image" />
                </div>
            </div>
        </section>

        <!-- <section class="scenario-section">
            <div class="scenario-container">
                <h2 class="scenario-label" data-reveal="true" style="--reveal-delay: 0.1s">THE SCENARIO</h2>
                <div class="scenario-quote-wrapper" data-reveal="true" style="--reveal-delay: 0.2s">
                    <p class="scenario-quote">You're staring at 200 pages of CIM with a first-pass memo due tomorrow
                        morning. You've got three other deals open and your model isn't done. Associum processes the
                        CIM, extracts the key financials, and drafts the memo structure before you've finished your
                        coffee.</p>
                </div>
                <p class="scenario-desc" data-reveal="true" style="--reveal-delay: 0.3s">Every output is fully cited,
                    traced back to the exact source document, page, and section it came from. <span
                        class="scenario-bold">No black box. No blind trust.</span></p>
            </div>
        </section> -->

        <section class="workflow-section">
            <div class="workflow-container">
                <div class="workflow-header">
                    <h2 class="workflow-title" data-reveal="true" style="--reveal-delay: 0.1s">An AI-powered end-to-end
                        workflow</h2>
                    <p class="workflow-desc" data-reveal="true" style="--reveal-delay: 0.2s">Associum's agents manage
                        the entire workflow of research and analysis, from raw inputs to a near-final deliverable you
                        can edit and send.</p>
                </div>

                <div class="workflow-track">
                    <div class="workflow-line" aria-hidden="true"></div>

                    <div class="workflow-cards">
                        <!-- Card 1 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.1s">
                            <span class="card-number">01</span>
                            <h3 class="card-title">Data Ingestion</h3>
                            <p class="card-text">Upload documents and datasets from any source. Associum reads,
                                classifies, and enriches every file with third-party data and deep web research.</p>
                            <div class="card-footer">
                                <span>Unstructured &rarr; Understanding</span>
                            </div>
                        </div>

                        <!-- Card 2 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.2s">
                            <span class="card-number">02</span>
                            <h3 class="card-title">Data extraction</h3>
                            <p class="card-text">Key financials, figures, risks, and data points are extracted and
                                indexed, each traced to its exact source document and page.</p>
                            <div class="card-footer">
                                <span>Data &rarr; Evidence</span>
                            </div>
                        </div>

                        <!-- Card 3 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.3s">
                            <span class="card-number">03</span>
                            <h3 class="card-title">Research synthesis</h3>
                            <p class="card-text">Findings are structured into coherent, investment-grade sections
                                calibrated to your output type, role, and firm standard.</p>
                            <div class="card-footer">
                                <span>Information &rarr; Insight</span>
                            </div>
                        </div>

                        <!-- Card 4 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.4s">
                            <span class="card-number">04</span>
                            <h3 class="card-title">Document generation</h3>
                            <p class="card-text">Associum produces a near-final memo, tearsheet, or report, formatted
                                and structured, ready for your analytical review.</p>
                            <div class="card-footer">
                                <span>Insight &rarr; Draft</span>
                            </div>
                        </div>

                        <!-- Card 5 -->
                        <div class="workflow-card" data-reveal="true" style="--reveal-delay: 0.5s">
                            <span class="card-number">05</span>
                            <h3 class="card-title">Edit and send</h3>
                            <p class="card-text">Refine the output in-platform. Adjust the thesis, sharpen the
                                narrative, apply firm conventions. Every element is editable before it leaves your
                                hands.</p>
                            <div class="card-footer">
                                <span>Draft &rarr; Decision</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="roles-section">
            <div class="roles-container">
                <div class="roles-header">
                    <span class="roles-label" data-reveal="true" style="--reveal-delay: 0.1s">WHO IT IS FOR</span>
                    <h2 class="roles-title" data-reveal="true" style="--reveal-delay: 0.2s">Built for every finance role
                    </h2>
                    <p class="roles-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum handles the document
                        work across the full spectrum of finance professionals, each with distinct outputs and
                        workflows.</p>
                </div>

                <div class="roles-layout" data-reveal="true" style="--reveal-delay: 0.1s">
                    <div class="roles-tabs" id="roles-tabs">
                        <button class="role-tab active" data-role="researchers">
                            Research
                        </button>
                        <button class="role-tab" data-role="public-markets">
                            Public Markets
                        </button>
                        <button class="role-tab" data-role="private-markets">
                            Private Markets
                        </button>
                        <button class="role-tab" data-role="private-bankers">
                            Private Banks
                        </button>
                        <button class="role-tab" data-role="investor-relations">
                            Investor Relations
                        </button>
                    </div>

                    <div class="role-content">
                        <div class="role-content-header">
                            <span class="content-label" id="role-content-label">RESEARCH</span>
                            <div class="role-title-group">
                                <h3 class="content-title" id="role-content-title">Go deep, quickly as markets,
                                    companies, and new trends evolve.</h3>
                                <p class="content-desc" id="role-content-desc">Associum pulls data from your trusted
                                    sources with deep web research to produce a well-cited fact base for your analysis
                                    and judgment.</p>
                            </div>
                        </div>

                        <div class="content-features">
                            <h4 class="features-label">WHAT ASSOCIUM HANDLES</h4>
                            <ul class="features-list" id="role-features-list">
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Pulls data from multiple trusted data sources autonomously.</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Cross-references past trends and proposes a thesis.</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Drafts a near-final, well-cited report, based on your templates</span>
                                </li>
                                <li>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="20 6 9 17 4 12"></polyline>
                                    </svg>
                                    <span>Your analysis, your judgment completes the view.</span>
                                </li>
                            </ul>
                        </div>

                        <div class="content-divider"></div>

                        <div class="content-sample">
                            <span class="features-label">SAMPLE OUTPUT</span>
                            <div class="sample-card">
                                <div class="sample-icon">
                                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                        <polyline points="14 2 14 8 20 8"></polyline>
                                        <line x1="16" y1="13" x2="8" y2="13"></line>
                                        <line x1="16" y1="17" x2="8" y2="17"></line>
                                        <polyline points="10 9 9 9 8 9"></polyline>
                                    </svg>
                                </div>
                                <div class="sample-info">
                                    <h5 id="role-sample-title">Market Research Report</h5>
                                    <p id="role-sample-desc">Multi-source synthesis structured into a cited, near-final
                                        research deliverable.</p>
                                </div>
                                <button class="sample-btn">Preview Template</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="insight-section">
            <div class="insight-container">
                <div class="insight-left">
                    <span class="insight-label" data-reveal="true" style="--reveal-delay: 0.1s">SOURCE- TRUTH
                        INSIGHT</span>
                    <h2 class="insight-title" data-reveal="true" style="--reveal-delay: 0.2s">Every number traces back
                        to its source.</h2>
                    <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum does not generate
                        figures from context or inference. Every data point in the output is extracted directly from the
                        documents you uploaded, cited back to the exact page and section it came from.</p>
                    <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.4s">Results from deep web
                        research and third-party data sources are also integrated inline with documents for
                        confirmation.</p>
                    <p class="insight-desc" data-reveal="true" style="--reveal-delay: 0.4s">You review the work. You
                        verify the sources. The judgment stays with you.</p>
                </div>
                <div class="insight-right" style="padding: 0; background: transparent; border: none; overflow: hidden;">
                    <video autoplay loop muted playsinline style="width: 100%; object-fit: cover; border-radius: 24px;">
                        <source src="/assets/images/finance/source/source.mov">
                        Your browser does not support the video tag.
                    </video>
                </div>
            </div>
        </section>

        <section class="automation-section">
            <div class="automation-container">
                <div class="automation-header">
                    <span class="automation-label" data-reveal="true" style="--reveal-delay: 0.1s">WORKFLOW
                        AUTOMATION</span>
                    <h2 class="automation-title" data-reveal="true" style="--reveal-delay: 0.2s">The work Associum
                        handles</h2>
                    <p class="automation-desc" data-reveal="true" style="--reveal-delay: 0.3s">Associum's agents manage
                        the entire workflow of research and analysis, helping you and your clients make high-stakes
                        decisions with better information, faster. Your judgement and decision-making, Associum's
                        support in building conviction.</p>
                </div>

                <div class="automation-layout" data-reveal="true" style="--reveal-delay: 0.1s">
                    <!-- Left Column: Without Associum -->
                    <div class="automation-col without-associum">
                        <div class="col-header">
                            <span class="col-badge">WITHOUT ASSOCIUM</span>
                            <h3 class="col-title">You dive into the dataroom - reading, cross-referencing, confirming,
                                and drafting.</h3>
                        </div>
                        <div class="pills-grid">
                            <span class="task-pill"><span class="pill-dot"></span>Read every filing</span>
                            <span class="task-pill"><span class="pill-dot"></span>Extract figures</span>
                            <span class="task-pill"><span class="pill-dot"></span>Cross-reference the model</span>
                            <span class="task-pill"><span class="pill-dot"></span>Chase missing data</span>
                            <span class="task-pill"><span class="pill-dot"></span>Build the memo outline</span>
                            <span class="task-pill"><span class="pill-dot"></span>Source comparable transactions</span>
                            <span class="task-pill"><span class="pill-dot"></span>Draft section by section</span>
                            <span class="task-pill"><span class="pill-dot"></span>Format to house style</span>
                            <span class="task-pill"><span class="pill-dot"></span>Add citations</span>
                            <span class="task-pill"><span class="pill-dot"></span>Tie out the numbers</span>
                            <span class="task-pill"><span class="pill-dot"></span>Reformat after feedback</span>
                        </div>
                    </div>

                    <!-- Divider Arrow -->
                    <div class="automation-divider-arrow">
                        <div class="arrow-circle">
                            <svg width="10" height="18" viewBox="0 0 10 18" fill="none" stroke="#37B793"
                                stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="2 2 8 9 2 16"></polyline>
                            </svg>
                        </div>
                    </div>

                    <!-- Right Column: With Associum -->
                    <div class="automation-col with-associum">
                        <div class="col-header">
                            <span class="col-badge badge-green">WITH ASSOCIUM</span>
                            <h3 class="col-title title-green">You provide direction and context. Associum handles the
                                rest.</h3>
                        </div>
                        <div class="pills-grid">
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Research
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Synthesis
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Drafting
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Citations
                            </span>
                            <span class="task-pill pill-green">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="20 6 9 17 4 12"></polyline>
                                </svg>
                                Formatting
                            </span>
                        </div>

                        <div class="col-footer-card">
                            <div class="footer-card-icon">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#37B793"
                                    stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10 9 9 9 8 9"></polyline>
                                </svg>
                            </div>
                            <div class="footer-card-info">
                                <h4>You review the draft</h4>
                                <p>Accurate, cited and ready for review</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="automation-bottom-banner" data-reveal="true" style="--reveal-delay: 0.2s">
                    <h3>More time for what really matters.</h3>
                    <p>Spend your time on analysis, thesis refinement, and client impact.</p>
                </div>
            </div>
        </section>

        <section class="faq-section">
            <div class="faq-container">
                <h2 class="faq-title" data-reveal="true" style="--reveal-delay: 0.1s">Common Questions from Finance
                    Professionals</h2>

                <div class="faq-list">
                    <div class="faq-item active" data-reveal="true" style="--reveal-delay: 0.1s">
                        <button class="faq-question">
                            Does Associum work with the document types that we actually use in finance?
                            <span class="faq-icon">−</span>
                        </button>
                        <div class="faq-answer" style="max-height: 200px;">
                            <p>Yes. Associum is built to handle CIMs, data room PDFs, SEC filings, earnings transcripts,
                                research reports, and financial model outputs. It reads the full document, not just the
                                first few pages.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.2s">
                        <button class="faq-question">
                            What stops it from hallucinating or making up numbers?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Every data point and claim in an Associum output is traced back to a specific source
                                document, page, and section. If it can't find something in the documents you've
                                uploaded, it won't invent it.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.3s">
                        <button class="faq-question">
                            Is our deal data secure?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Associum is SOC 2 certified and ISO 27001 compliant. Your documents are never used to
                                train any AI model. Data handling details are available on our Security page.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.4s">
                        <button class="faq-question">
                            How long does it take to get a usable output
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>Most users have a structured first draft (memo, tearsheet, or summary) within 20–30
                                minutes of uploading their documents, depending on document volume.</p>
                        </div>
                    </div>

                    <div class="faq-item" data-reveal="true" style="--reveal-delay: 0.5s">
                        <button class="faq-question">
                            Do I need to set anything up or train it on our firm’s style?
                            <span class="faq-icon">+</span>
                        </button>
                        <div class="faq-answer">
                            <p>No setup required. Upload your documents and start. For teams that want outputs in a
                                specific house format, templates can be configured, but it works out of the box from day
                                one.</p>
                        </div>
                    </div>
                </div>

                <p class="faq-footer" data-reveal="true" style="--reveal-delay: 0.2s">Still have a question? Use the
                    form on our Contact page and we'll be in touch within one business day.</p>
            </div>
        </section>

        <section class="cta-section">
            <div class="cta-wrapper">
                <div class="cta-container">
                    <h2 class="cta-title" data-reveal="true" style="--reveal-delay: 0.1s">From data to near-final
                        draft.<br>In one environment.</h2>
                    <p class="cta-desc" data-reveal="true" style="--reveal-delay: 0.2s">Free to start. No credit card
                        required.</p>
                    <div class="cta-buttons" data-reveal="true" style="--reveal-delay: 0.3s">
                        <button class="cta-btn-primary">Start for Free</button>
                        <button class="cta-btn-outline">See Pricing</button>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer will be injected here -->
    <footer id="footer-placeholder"></footer>

    <!-- Component Loader Script -->
    
    <!-- Finance Script -->
    

</Layout>

<style>
.finance-main {
    display: block;
    min-height: auto;
    padding: 0;
    background-color: transparent;
}

.finance-hero {
    display: flex;
    height: auto;
    /* Allow height to adapt */
    min-height: 650px;
    padding: 200px 80px 160px 80px;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    flex-shrink: 0;
    align-self: stretch;
    background: linear-gradient(226deg, #043525 25.28%, #021B13 89%);
    overflow: hidden;
}

.hero-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 1240px;
    margin: 0 auto;
    gap: 30px;
    height: 100%;
}

.hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 23.1px;
    flex: 1 0 0;
}

.hero-pill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5.5px 15px 5.64px;
    border-radius: 9999px;
    background: rgba(52, 211, 153, 0.12);
    border: 1px solid rgba(52, 211, 153, 0.25);
}

.hero-pill .pill-dot {
    position: relative;
    width: 6px;
    height: 6px;
    background-color: #34D399;
    border-radius: 50%;
    box-shadow: 0px 0px 8px 0px #34D399;
}

.hero-pill .pill-dot::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    background-color: #34D399;
    border-radius: 50%;
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.8;
    animation: pill-dot-active 2s infinite cubic-bezier(0.25, 0, 0, 1);
}

.pill-text {
    color: #34D399;
    font-family: Inter, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.1px;
    text-transform: uppercase;
}

@keyframes pill-dot-active {
    0% {
        transform: translate(-50%, -50%) scale(1);
        opacity: 0.8;
    }

    100% {
        transform: translate(-50%, -50%) scale(3.5);
        opacity: 0;
    }
}

.hero-title {
    margin: 0;
    color: #FFF;
    font-family: 'Lato', sans-serif;
    font-size: 52px;
    font-weight: 700;
    line-height: 1.1;
}

.hero-highlight {
    color: #68F0A7;
    /* Brighter neon green to match image */
}

.hero-desc {
    color: #B7C3D2;
    font-family: Inter, sans-serif;
    font-size: 18px;
    line-height: 28px;
    max-width: 480px;
    margin: 0;
}

.hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 10px;
}

.hero-btn {
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 500;
}

.hero-right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    border-radius: 8px 0 0 0;
    flex: 1;
    padding-left: 40px;
    padding-top: 40px;
    position: relative;
    margin-top: auto;
}

.hero-image {
    width: 100%;
    height: auto;
    border-top-left-radius: 12px;
}

/* Responsive tweaks */
@media (max-width: 1120px) {
    .finance-hero {
